{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "TeamWorkflowHandoff": {
      "properties": {
        "activeDelegateCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "awaitingReviewCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "blockedDelegateCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "integrationReadyCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "state": {
          "$ref": "#/definitions/TeamWorkflowLifecycleState"
        },
        "traceGroupId": {
          "type": "string"
        }
      },
      "required": [
        "activeDelegateCount",
        "awaitingReviewCount",
        "blockedDelegateCount",
        "integrationReadyCount",
        "state",
        "traceGroupId"
      ],
      "type": "object"
    },
    "TeamWorkflowLifecycle": {
      "properties": {
        "blocked": {
          "type": "boolean"
        },
        "integrationReady": {
          "type": "boolean"
        },
        "lastTransitionAt": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/definitions/TeamWorkflowPhase"
        },
        "reviewRequired": {
          "type": "boolean"
        },
        "state": {
          "$ref": "#/definitions/TeamWorkflowLifecycleState"
        },
        "traceGroupId": {
          "type": "string"
        }
      },
      "required": [
        "blocked",
        "integrationReady",
        "lastTransitionAt",
        "phase",
        "reviewRequired",
        "state",
        "traceGroupId"
      ],
      "type": "object"
    },
    "TeamWorkflowLifecycleState": {
      "enum": [
        "bootstrap",
        "designing",
        "developing",
        "reviewing",
        "replanning",
        "blocked",
        "integration_ready"
      ],
      "type": "string"
    },
    "TeamWorkflowMemoryProvider": {
      "properties": {
        "health": {
          "$ref": "#/definitions/TeamWorkflowMemoryProviderHealth"
        },
        "mode": {
          "$ref": "#/definitions/TeamWorkflowMemoryProviderMode"
        }
      },
      "required": [
        "health",
        "mode"
      ],
      "type": "object"
    },
    "TeamWorkflowMemoryProviderHealth": {
      "enum": [
        "ready",
        "degraded"
      ],
      "type": "string"
    },
    "TeamWorkflowMemoryProviderMode": {
      "enum": [
        "local",
        "tape"
      ],
      "type": "string"
    },
    "TeamWorkflowPhase": {
      "enum": [
        "bootstrap",
        "design",
        "development",
        "review",
        "replan"
      ],
      "type": "string"
    },
    "TeamWorkflowRootAgent": {
      "properties": {
        "agentId": {
          "type": "string"
        },
        "entrypoint": {
          "type": "string"
        },
        "nestedAgentsPublic": {
          "type": "boolean"
        },
        "role": {
          "type": "string"
        },
        "threadId": {
          "type": "string"
        }
      },
      "required": [
        "agentId",
        "entrypoint",
        "nestedAgentsPublic",
        "role",
        "threadId"
      ],
      "type": "object"
    },
    "TeamWorkflowSession": {
      "properties": {
        "activeTeamCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "blockedTeamCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "currentPhase": {
          "$ref": "#/definitions/TeamWorkflowPhase"
        },
        "globalGovernancePath": {
          "type": "string"
        },
        "handoff": {
          "$ref": "#/definitions/TeamWorkflowHandoff"
        },
        "lifecycle": {
          "$ref": "#/definitions/TeamWorkflowLifecycle"
        },
        "maxDepth": {
          "format": "int32",
          "type": "integer"
        },
        "memoryProvider": {
          "$ref": "#/definitions/TeamWorkflowMemoryProvider"
        },
        "rootAgent": {
          "$ref": "#/definitions/TeamWorkflowRootAgent"
        },
        "rootRole": {
          "type": "string"
        },
        "rootTeamId": {
          "type": "string"
        },
        "rootThreadId": {
          "type": "string"
        },
        "staleResourceCount": {
          "format": "uint",
          "minimum": 0.0,
          "type": "integer"
        },
        "teamStateIndexPath": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": [
        "activeTeamCount",
        "blockedTeamCount",
        "currentPhase",
        "globalGovernancePath",
        "handoff",
        "lifecycle",
        "maxDepth",
        "memoryProvider",
        "rootAgent",
        "rootRole",
        "rootTeamId",
        "rootThreadId",
        "staleResourceCount",
        "teamStateIndexPath",
        "updatedAt"
      ],
      "type": "object"
    }
  },
  "properties": {
    "session": {
      "$ref": "#/definitions/TeamWorkflowSession"
    }
  },
  "required": [
    "session"
  ],
  "title": "TeamWorkflowSessionUpdatedNotification",
  "type": "object"
}